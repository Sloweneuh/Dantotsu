<!--
  MangaBaka's "unweighted" indicator: a chevron drawn with a dashed round-capped stroke
  (their SVG uses stroke-dasharray="1.6 1.6", stroke-linecap="round"). VectorDrawable has no
  dash-array, so the chevron is split into round-capped dashes. The pattern is centred on the
  peak so the mark is symmetric, aligned with the other weight chevrons at viewport y=11.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M6.34,12.77 L8.61,11.26" />
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M10.87,9.75 L12,9 L13.13,9.75" />
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M15.39,11.26 L17.66,12.77" />
</vector>
