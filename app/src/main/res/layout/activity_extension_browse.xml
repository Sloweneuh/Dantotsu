<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/extensionBrowseRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/extensionBrowseToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/nav_bg_inv"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <ImageButton
                android:id="@+id/extensionBrowseBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackground"
                android:contentDescription="@string/back"
                android:padding="12dp"
                app:srcCompat="@drawable/ic_round_arrow_back_ios_new_24"
                app:tint="?attr/colorOnBackground"
                tools:ignore="SpeakableTextPresentCheck" />
        </androidx.cardview.widget.CardView>

        <ImageView
            android:id="@+id/extensionBrowseIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/extensionBrowseTitle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            tools:text="Extension Name" />

        <ImageButton
            android:id="@+id/extensionBrowseLanguage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/language"
            android:padding="12dp"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_round_translate_24"
            app:tint="?attr/colorOnBackground"
            tools:visibility="visible" />
    </LinearLayout>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/extensionBrowseChipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:singleLine="true"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPopular"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:checked="true"
            android:fontFamily="@font/poppins_semi_bold"
            android:text="@string/popular"
            app:checkedIconVisible="false"
            app:chipIcon="@drawable/ic_round_star_24"
            app:chipIconTint="?attr/colorOnBackground"
            app:chipIconVisible="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipLatest"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:fontFamily="@font/poppins_semi_bold"
            android:text="@string/latest"
            app:checkedIconVisible="false"
            app:chipIcon="@drawable/ic_round_new_releases_24"
            app:chipIconTint="?attr/colorOnBackground"
            app:chipIconVisible="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFilter"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:fontFamily="@font/poppins_semi_bold"
            android:text="@string/filter"
            app:checkedIconVisible="false"
            app:chipIcon="@drawable/ic_round_filter_alt_24"
            app:chipIconTint="?attr/colorOnBackground"
            app:chipIconVisible="true" />
    </com.google.android.material.chip.ChipGroup>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/extensionBrowseRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"
            tools:itemCount="8"
            tools:layoutManager="GridLayoutManager"
            tools:listitem="@layout/item_extension_media"
            tools:spanCount="3" />

        <ProgressBar
            android:id="@+id/extensionBrowseProgress"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/extensionBrowseEmptyContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="@string/nothing_here"
                android:src="@drawable/ic_round_search_off_24"
                app:tint="?attr/colorOnBackground" />

            <TextView
                android:id="@+id/extensionBrowseEmptyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/poppins"
                android:text="@string/no_results_found"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
