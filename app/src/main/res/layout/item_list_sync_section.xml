<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="24dp"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/sectionHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/sectionChevron"
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:srcCompat="@drawable/ic_round_arrow_drop_down_24"
            app:tint="?attr/colorOnBackground"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/sectionIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            app:tint="?attr/colorPrimary"
            tools:ignore="ContentDescription"
            tools:srcCompat="@drawable/ic_myanimelist" />

        <TextView
            android:id="@+id/sectionLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/poppins_bold"
            android:textColor="?attr/colorOnBackground"
            android:textSize="18sp"
            tools:text="Anime" />

        <TextView
            android:id="@+id/sectionCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:fontFamily="@font/poppins_bold"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            tools:text="12" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sectionSyncAll"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="48dp"
            android:paddingHorizontal="14dp"
            android:text=""
            android:contentDescription="@string/sync_all"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_round_sync_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/statsSourceIcons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="24dp"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/statsSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_semi_bold"
                android:lineSpacingExtra="2dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="Total 312\nCurrent 40" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/statsDestIcons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="24dp"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/statsDest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_semi_bold"
                android:lineSpacingExtra="2dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="Total 305\nCurrent 38" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/sectionEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:alpha="0.66"
        android:fontFamily="@font/poppins_semi_bold"
        android:text="@string/list_sync_up_to_date"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sectionDiffList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:nestedScrollingEnabled="false"
        android:visibility="gone"
        tools:itemCount="2"
        tools:listitem="@layout/item_list_sync_diff"
        tools:visibility="visible" />
</LinearLayout>
