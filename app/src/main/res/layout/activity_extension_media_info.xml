<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/extensionInfoRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/extensionInfoHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/extensionInfoBanner"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:scaleType="centerCrop"
                    tools:ignore="ContentDescription"
                    tools:srcCompat="@tools:sample/backgrounds/scenic" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:alpha="0.6"
                    android:src="@drawable/linear_gradient_bg"
                    tools:ignore="ContentDescription" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/extensionInfoBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="56dp"
                    android:layout_marginEnd="16dp"
                    android:translationZ="7dp"
                    app:cardBackgroundColor="@color/nav_bg"
                    app:cardCornerRadius="16dp">

                    <androidx.constraintlayout.utils.widget.ImageFilterView
                        android:id="@+id/extensionInfoBackImage"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/back"
                        android:src="@drawable/ic_round_close_24"
                        tools:ignore="SpeakableTextPresentCheck" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="112dp"
                        android:layout_height="168dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/extensionInfoCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/roundedImageView"
                            tools:ignore="ContentDescription"
                            tools:srcCompat="@tools:sample/backgrounds/scenic" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="168dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/extensionInfoTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/poppins_bold"
                            android:maxLines="3"
                            android:shadowColor="@color/bg_black"
                            android:shadowDx="0"
                            android:shadowDy="0"
                            android:shadowRadius="4"
                            android:textColor="@color/bg_white"
                            android:textSize="18sp"
                            tools:text="Media Title" />

                        <TextView
                            android:id="@+id/extensionInfoAuthor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/poppins"
                            android:maxLines="2"
                            android:shadowColor="@color/bg_black"
                            android:shadowDx="0"
                            android:shadowDy="0"
                            android:shadowRadius="4"
                            android:textColor="@color/bg_white"
                            android:textSize="12sp"
                            android:visibility="gone"
                            tools:text="Author"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/extensionInfoStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/poppins"
                            android:shadowColor="@color/bg_black"
                            android:shadowDx="0"
                            android:shadowDy="0"
                            android:shadowRadius="4"
                            android:textColor="@color/bg_white"
                            android:textSize="12sp"
                            android:visibility="gone"
                            tools:text="Ongoing"
                            tools:visibility="visible" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:text="@string/search"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/extensionInfoSearchAnilist"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="@string/search_anilist"
                    android:textAlignment="viewStart"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_anilist"
                    app:iconPadding="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/extensionInfoSearchMu"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="@string/search_mangaupdates"
                    android:textAlignment="viewStart"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    app:icon="@drawable/ic_round_mangaupdates_24"
                    app:iconPadding="16dp"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/extensionInfoGenresTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="@string/genres"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/extensionInfoGenresChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/extensionInfoSynopsisTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="@string/description"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/extensionInfoSynopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:text="Synopsis text here."
                    tools:visibility="visible" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/extensionInfoProgress"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="gone"
        tools:visibility="visible" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
