<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="44dp"
        android:layout_height="62dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/itemMediaCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:ignore="ContentDescription"
            tools:src="@tools:sample/backgrounds/scenic" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemMediaTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_bold"
            android:maxLines="1"
            android:textSize="14sp"
            tools:text="One Piece" />

        <TextView
            android:id="@+id/itemMediaSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:fontFamily="@font/poppins_semi_bold"
            android:maxLines="1"
            android:textSize="12sp"
            tools:text="12 items · 45.2 MB" />
    </LinearLayout>

    <ImageView
        android:id="@+id/itemMediaDelete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/delete"
        android:padding="8dp"
        app:srcCompat="@drawable/ic_round_delete_24"
        app:tint="?attr/colorOnBackground" />

    <ImageView
        android:id="@+id/itemMediaExpand"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/expand"
        android:padding="8dp"
        android:rotation="90"
        app:srcCompat="@drawable/ic_round_arrow_back_ios_new_24"
        app:tint="?attr/colorOnBackground" />

</LinearLayout>
