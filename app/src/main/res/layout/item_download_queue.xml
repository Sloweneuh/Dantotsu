<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="16dp"
    android:paddingVertical="8dp">

    <ImageView
        android:id="@+id/itemDownloadDrag"
        android:layout_width="32dp"
        android:layout_height="40dp"
        android:contentDescription="@string/reorder"
        android:paddingHorizontal="4dp"
        app:srcCompat="@drawable/ic_round_drag_indicator_24"
        app:tint="?attr/colorOnBackground" />

    <androidx.cardview.widget.CardView
        android:layout_width="48dp"
        android:layout_height="68dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/itemDownloadCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:ignore="ContentDescription"
            tools:src="@tools:sample/backgrounds/scenic" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemDownloadTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_bold"
            android:maxLines="1"
            android:textSize="14sp"
            tools:text="One Piece" />

        <TextView
            android:id="@+id/itemDownloadLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_semi_bold"
            android:maxLines="1"
            android:textColor="?attr/colorSecondary"
            android:textSize="12sp"
            tools:text="Chapter 1 - Chapter 10" />

        <TextView
            android:id="@+id/itemDownloadStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:ellipsize="end"
            android:fontFamily="@font/poppins"
            android:maxLines="1"
            android:textSize="11sp"
            tools:text="42% · 1.2 MB/s · ETA 0:35 · 5.1 MB" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/itemDownloadProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:trackCornerRadius="4dp"
            tools:progress="42" />
    </LinearLayout>

    <ImageView
        android:id="@+id/itemDownloadCancel"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cancel_download"
        android:padding="8dp"
        app:srcCompat="@drawable/ic_round_close_24"
        app:tint="?attr/colorOnBackground" />

</LinearLayout>
