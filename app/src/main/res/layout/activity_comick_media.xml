<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/comickMediaScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/comickMediaRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Banner + cover + title header -->
            <FrameLayout
                android:id="@+id/comickMediaHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/comickMediaBanner"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerCrop"
                    tools:ignore="ContentDescription" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:alpha="0.7"
                    android:src="@drawable/linear_gradient_bg"
                    tools:ignore="ContentDescription" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="112dp"
                        android:layout_height="168dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/comickMediaCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/roundedImageView"
                            tools:ignore="ContentDescription" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="168dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/comickMediaTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/poppins_bold"
                            android:maxLines="4"
                            android:shadowColor="@color/bg_black"
                            android:shadowDx="0"
                            android:shadowDy="0"
                            android:shadowRadius="8"
                            android:textColor="@color/bg_white"
                            android:textSize="18sp"
                            tools:text="Comic Title" />

                        <TextView
                            android:id="@+id/comickMediaScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:shadowColor="@color/bg_black"
                            android:shadowDx="0"
                            android:shadowDy="0"
                            android:shadowRadius="8"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="15sp"
                            tools:text="★ 8.54" />
                    </LinearLayout>
                </LinearLayout>

            </FrameLayout>

            <!-- Source buttons (AniList + MangaUpdates) -->
            <LinearLayout
                android:id="@+id/comickMediaSourceButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/comickMediaAnilistBtn"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="@string/comick_open_anilist"
                    android:textAlignment="viewStart"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    app:icon="@drawable/ic_anilist"
                    app:iconPadding="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/comickMediaMuBtn"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="@string/comick_open_mangaupdates"
                    android:textAlignment="viewStart"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    app:icon="@drawable/ic_round_mangaupdates_24"
                    app:iconPadding="16dp" />

            </LinearLayout>

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/comickMediaProgress"
                style="?android:attr/progressBarStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="32dp"
                android:indeterminate="true"
                android:visibility="visible" />

            <!-- Dynamic content container -->
            <LinearLayout
                android:id="@+id/comickMediaContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating close button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/comickMediaClose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:translationZ="7dp"
        app:cardBackgroundColor="@color/nav_bg"
        app:cardCornerRadius="16dp">

        <androidx.constraintlayout.utils.widget.ImageFilterView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_round_close_24"
            tools:ignore="SpeakableTextPresentCheck" />

    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
