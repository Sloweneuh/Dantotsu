<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Collapsing header -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <FrameLayout
            android:id="@+id/comickMediaHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="scroll|snap">

            <ImageView
                android:id="@+id/comickMediaBanner"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                tools:ignore="ContentDescription" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:alpha="0.7"
                android:src="@drawable/linear_gradient_bg"
                tools:ignore="ContentDescription" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="112dp"
                    android:layout_height="168dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/comickMediaCover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/roundedImageView"
                        tools:ignore="ContentDescription" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="168dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:gravity="bottom"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/comickMediaTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_bold"
                        android:maxLines="4"
                        android:shadowColor="@color/bg_black"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="8"
                        android:textColor="@color/bg_white"
                        android:textSize="18sp"
                        tools:text="Comic Title" />

                    <TextView
                        android:id="@+id/comickMediaScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:shadowColor="@color/bg_black"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="8"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="15sp"
                        tools:text="★ 8.54" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content pages — direct CoordinatorLayout child so it resizes correctly -->
    <FrameLayout
        android:id="@+id/comickMediaPages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Loading indicator (shown before content loads) -->
        <ProgressBar
            android:id="@+id/comickMediaProgress"
            style="?android:attr/progressBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_margin="32dp"
            android:indeterminate="true"
            android:visibility="visible" />

        <!-- Info tab content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/comickMediaInfoScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Source buttons (AniList + MangaUpdates) -->
                <LinearLayout
                    android:id="@+id/comickMediaSourceButtons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/comickMediaAnilistBtn"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/poppins_bold"
                        android:text="@string/comick_open_anilist"
                        android:textAlignment="viewStart"
                        android:textAllCaps="false"
                        android:visibility="gone"
                        app:icon="@drawable/ic_anilist"
                        app:iconPadding="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/comickMediaMuBtn"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/poppins_bold"
                        android:text="@string/comick_open_mangaupdates"
                        android:textAlignment="viewStart"
                        android:textAllCaps="false"
                        android:visibility="gone"
                        app:icon="@drawable/ic_round_mangaupdates_24"
                        app:iconPadding="16dp" />

                </LinearLayout>

                <!-- Dynamic info content injected in code -->
                <LinearLayout
                    android:id="@+id/comickMediaContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Chapters tab content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/comickMediaChaptersScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Chapter count / missing-chapter header -->
                <TextView
                    android:id="@+id/comickChaptersHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:text="@string/chaps"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- Chip group for range navigation (visibility controlled in code) -->
                <HorizontalScrollView
                    android:id="@+id/comickChaptersChipScroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:scrollbars="none"
                    android:visibility="visible">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/comickChaptersChipGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true" />
                </HorizontalScrollView>

                <!-- Empty state when no chapters are available -->
                <TextView
                    android:id="@+id/comickChaptersEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center"
                    android:padding="32dp"
                    android:text="@string/no_chapter"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <!-- Chapters loading indicator -->
                <ProgressBar
                    android:id="@+id/comickChaptersProgress"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="32dp"
                    android:indeterminate="true"
                    android:visibility="gone" />

                <!-- Chapter items injected in code -->
                <LinearLayout
                    android:id="@+id/comickChaptersList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <!-- Bottom navigation bar — pinned, independent of the scrolling content -->
    <nl.joery.animatedbottombar.AnimatedBottomBar
        android:id="@+id/comickMediaBottomBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:padding="0dp"
        app:abb_animationInterpolator="@anim/over_shoot"
        app:abb_indicatorAppearance="round"
        app:abb_indicatorLocation="top"
        app:abb_selectedTabType="text"
        app:abb_textAppearance="@style/NavBarText"
        app:itemActiveIndicatorStyle="@style/BottomNavBar"
        app:itemIconTint="@color/tab_layout_icon"
        app:itemRippleColor="#00000000"
        app:itemTextAppearanceActive="@style/NavBarText"
        app:itemTextAppearanceInactive="@style/NavBarText"
        app:itemTextColor="@color/tab_layout_icon" />

    <!-- Floating close button — always on top -->
    <androidx.cardview.widget.CardView
        android:id="@+id/comickMediaClose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:translationZ="7dp"
        app:cardBackgroundColor="@color/nav_bg"
        app:cardCornerRadius="16dp">

        <androidx.constraintlayout.utils.widget.ImageFilterView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_round_close_24"
            tools:ignore="SpeakableTextPresentCheck" />

    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
