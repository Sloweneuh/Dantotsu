<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/downloadQueueCancelAllContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:visibility="gone"
        tools:ignore="UseCompoundDrawables">

        <TextView
            android:id="@+id/downloadQueueCancelAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:drawablePadding="8dp"
            android:fontFamily="@font/poppins_semi_bold"
            android:padding="12dp"
            android:text="@string/cancel_all_downloads"
            android:textColor="?attr/colorError"
            android:textSize="14sp"
            app:drawableStartCompat="@drawable/ic_round_delete_24"
            app:drawableTint="?attr/colorError" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/downloadQueueRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="24dp" />

        <TextView
            android:id="@+id/downloadQueueEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alpha="0.6"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/download_queue_empty"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
