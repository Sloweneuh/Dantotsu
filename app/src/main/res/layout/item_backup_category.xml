<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/backupCategoryRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <ImageView
        android:id="@+id/backupCategoryChevron"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@string/backup_expand_collapse"
        android:src="@drawable/ic_round_arrow_drop_down_24" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/backupCategoryCheckbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="0dp">

        <TextView
            android:id="@+id/backupCategoryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/backupCategoryDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:fontFamily="@font/poppins"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
